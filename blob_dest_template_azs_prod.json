{
  "type": "azure_blob",
  "containerName": "",
  "streamtags": [],
  "environment": "prod",
  "region": "southcentralus",
  "storageAccountName": "prodstorageazs",
  "authenticationMethod": "connectionString",
  "connectionString": "DefaultEndpointsProtocol=https;AccountName=prodstorageazs;AccountKey=REPLACE_ME;EndpointSuffix=core.windows.net",
  "partitionExpr": "`${host}/${sourcetype}`",
  "format": "raw",
  "compress": "gzip",
  "maxFileSizeMB": 32,
  "maxFileOpenTimeSec": 300,
  "maxFileIdleTimeSec": 30,
  "maxOpenFiles": 100,
  "onBackpressure": "block",
  "stagePath": "/tmp/cribl-staging",
  "destPath": "",
  "addIdToStagePath": true,
  "removeEmptyDirs": false
}

# Copy this file to .env and fill in real values.
# docker-compose reads .env automatically.

# ── cribl-service: Cribl Stream connection ──────────────────────────────────────
CRIBL_BASE_URL=https://cribl-leader.example.com:9000
# Use token OR username+password (token takes priority)
CRIBL_TOKEN=
CRIBL_USERNAME=admin
CRIBL_PASSWORD=
CRIBL_SKIP_SSL=false

# ── ece-service: Elasticsearch — nonprod ───────────────────────────────────────
ECE_ES_URL=https://es-nonprod.example.com:9200
# Use ApiKey token OR username+password (token takes priority)
ECE_ES_TOKEN=
ECE_ES_USERNAME=elastic
ECE_ES_PASSWORD=

# ── ece-service: Elasticsearch — prod ─────────────────────────────────────────
ECE_ES_URL_PROD=https://es-prod.example.com:9200
ECE_ES_TOKEN_PROD=
ECE_ES_USERNAME_PROD=elastic
ECE_ES_PASSWORD_PROD=

# ── ece-service: Kibana ────────────────────────────────────────────────────────
ECE_KIBANA_URL=https://kibana.example.com:5601
ECE_KIBANA_TOKEN=
ECE_KIBANA_USERNAME=elastic
ECE_KIBANA_PASSWORD=

# ── Shared ─────────────────────────────────────────────────────────────────────
ECE_SKIP_SSL=false
LOG_LEVEL=INFO

# cribl_service environment variables
# Copy to .env and fill in real values before running docker-compose

# ── Cribl Stream connection ──────────────────────────────────────────────────
CRIBL_BASE_URL=https://cribl.example.com:9000

# Authentication — use TOKEN or USERNAME+PASSWORD (token takes priority)
CRIBL_TOKEN=
CRIBL_USERNAME=admin
CRIBL_PASSWORD=

# ── TLS / timeouts ───────────────────────────────────────────────────────────
CRIBL_SKIP_SSL=false
CRIBL_TIMEOUT=30

# ── Defaults ─────────────────────────────────────────────────────────────────
CRIBL_DEFAULT_WORKSPACE=default
CRIBL_DEFAULT_ROUTES_TABLE=default
CRIBL_MIN_EXISTING_ROUTES=1
CRIBL_SNAPSHOT_DIR=cribl_snapshots

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

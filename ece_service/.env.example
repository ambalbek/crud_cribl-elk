# ece_service environment variables
# Copy to .env and fill in real values — never commit .env to source control.

# ── Elasticsearch — nonprod ──────────────────────────────────────────────────
ECE_ES_URL=https://your-nonprod-es-host:9200
# Use either token (ApiKey) or username+password:
ECE_ES_TOKEN=
ECE_ES_USERNAME=
ECE_ES_PASSWORD=

# ── Elasticsearch — prod ─────────────────────────────────────────────────────
ECE_ES_URL_PROD=https://your-prod-es-host:9200
ECE_ES_TOKEN_PROD=
ECE_ES_USERNAME_PROD=
ECE_ES_PASSWORD_PROD=

# ── Kibana ────────────────────────────────────────────────────────────────────
ECE_KIBANA_URL=https://your-kibana-host:5601
ECE_KIBANA_TOKEN=
ECE_KIBANA_USERNAME=
ECE_KIBANA_PASSWORD=

# ── Shared ────────────────────────────────────────────────────────────────────
ECE_SKIP_SSL=false
ECE_TIMEOUT=60
ECE_TEMPLATES_DIR=ops_rm_r_templates_output
LOG_LEVEL=INFO
